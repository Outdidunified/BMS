# Ingestion target (matches BACKEND app.js default ports)
INGEST_HOST=http://backend
INGEST_PORT=8072
INGEST_PATH=/data
API_KEY=replace-with-device-api-key

# Single-device fallback (ignored when NUM_DEVICES>1)
DI=BMS001
BI=BAT1001
MI=00:1A:7D:DA:71:13

# Multi-device simulation
NUM_DEVICES=5
START_INDEX=1
DI_PREFIX=BMS
BI_PREFIX=BAT
STAGGER_MS=250
# Optionally define explicit devices (overrides NUM_DEVICES when set):
DEVICES_JSON='[{"DI":"BMS001","BI":"BAT1001","MI":"02:00:00:00:00:01"},{"DI":"BMS002","BI":"BAT1002","MI":"02:00:00:00:00:02"},{"DI":"BMS003","BI":"BAT1003","MI":"02:00:00:00:00:03"},{"DI":"BMS004","BI":"BAT1004","MI":"02:00:00:00:00:04"},{"DI":"BMS005","BI":"BAT1005","MI":"02:00:00:00:00:05"},{
  "deviceId": "BMS009",
  "batteryId": "BAT1009",
  "macId": "00:1A:7D:DA:71:96"
}]'
# DEVICES_CSV='BMS001,BAT1001,02:00:00:00:00:01;BMS002,BAT1002,02:00:00:00:00:02'

# Simulator timing
# Either set FPS (frames per second) OR a fixed interval in ms. If INTERVAL_MS>0, it takes precedence.
FPS=4
INTERVAL_MS=5000   # send once every 5 seconds
JITTER_MS=20       # random jitter used only when INTERVAL_MS=0
LOG_FILE=simulator.log